{
  "enabled": true,
  "network": {
    "allowedDomains": [
      "context7.com",
      "*.context7.com",
      "github.com",
      "*.github.com",
      "api.github.com",
      "raw.githubusercontent.com",
      "registry.npmjs.org",
      "pypi.org",
      "*.pypi.org"
    ],
    "deniedDomains": []
  },
  "filesystem": {
    "denyRead": ["~/.ssh", "~/.aws", "~/.gnupg"],
    "allowWrite": [".", "/tmp"],
    "denyWrite": [".env", ".env.*", "*.pem", "*.key"]
  }
}
