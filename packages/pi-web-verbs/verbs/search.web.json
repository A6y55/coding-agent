{
  "schemaVersion": "1.0",
  "name": "search.web",
  "version": "1.1.0",
  "description": "Search the public web in a Playwright browser and return structured results without a paid API.",
  "tags": ["search", "web", "playwright", "discovery"],
  "sites": ["duckduckgo.com", "bing.com"],
  "inputSchema": {
    "type": "object",
    "properties": {
      "query": { "type": "string", "minLength": 1, "maxLength": 500 },
      "max_results": { "type": "integer", "minimum": 1, "maximum": 20, "default": 10 },
      "engine": { "type": "string", "enum": ["auto", "duckduckgo", "bing"], "default": "auto" }
    },
    "required": ["query"],
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "query": { "type": "string" },
      "results": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "url": { "type": "string", "format": "uri" },
            "content": { "type": "string" },
            "engines": { "type": "array", "items": { "type": "string" } },
            "score": { "type": "number" },
            "published_date": { "type": ["string", "null"] },
            "thumbnail": { "type": ["string", "null"] }
          },
          "required": ["title", "url", "content", "engines", "score", "published_date", "thumbnail"],
          "additionalProperties": false
        }
      },
      "answers": { "type": "array", "items": { "type": "string" } },
      "corrections": { "type": "array", "items": { "type": "string" } },
      "suggestions": { "type": "array", "items": { "type": "string" } },
      "unresponsive_engines": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": { "engine": { "type": "string" }, "error": { "type": "string" } },
          "required": ["engine", "error"],
          "additionalProperties": false
        }
      }
    },
    "required": ["query", "results", "answers", "corrections", "suggestions", "unresponsive_engines"],
    "additionalProperties": false
  },
  "preconditions": [],
  "postconditions": [
    {
      "id": "supported-search-domain",
      "description": "The browser remains on a supported search domain after extraction.",
      "kind": "url-matches",
      "value": "^https://(html\\.duckduckgo\\.com|([a-z]{2}\\.)?bing\\.com)/"
    }
  ],
  "auth": { "required": false },
  "risk": "read",
  "sideEffects": [],
  "implementations": [
    {
      "id": "playwright-browser",
      "backend": "browser",
      "module": "pi_web_verbs_sidecar.verbs.web_search_browser",
      "function": "execute",
      "requestClass": "SearchRequest",
      "responseClass": "SearchResponse",
      "priority": 100
    }
  ],
  "status": "tested",
  "tests": { "status": "passing", "revision": "builtin-mock" }
}
